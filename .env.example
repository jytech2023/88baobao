# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---------- Auth.js (Auth0 provider) ----------
# openssl rand -base64 32
AUTH_SECRET=
# Auth0 application: Regular Web App
# Allowed Callback URL: {NEXT_PUBLIC_APP_URL}/api/auth/callback/auth0
AUTH_AUTH0_ID=
AUTH_AUTH0_SECRET=
AUTH_AUTH0_ISSUER=https://YOUR_TENANT.us.auth0.com

# ---------- Database (Neon) ----------
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# ---------- Cloudinary (image hosting & transforms) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ---------- Twilio (SMS) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------- Resend (Email) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---------- Market Monitoring data sources ----------
# Google Places API (reviews + nearby search). $200/mo free credit.
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API. Free 5000/day. https://docs.developer.yelp.com/
YELP_API_KEY=

# Reddit (script app). Free. https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=88baobao/0.1 by jytech2023

# Serper.dev — Google Search / Maps / News. Free 2500 queries.
# https://serper.dev/
SERPER_API_KEY=

# ---------- Vercel AI Gateway (LLM for review classification & content) ----------
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# ---------- Alerts (Feishu / Slack webhook) ----------
FEISHU_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ---------- Cron secret (for scheduled jobs) ----------
CRON_SECRET=

# ---------- Social sync (IG / TikTok → FB via Buffer) ----------
# Apify — IG/TikTok scraping + KV state for dedupe
APIFY_TOKEN=

# Buffer — posts to the connected FB-page channel
BUFFER_API_KEY=
BUFFER_CHANNEL_ID=
BUFFER_ORGANIZATION_ID=

# Sources (each is optional — leave blank to disable)
IG_USERNAME=88baobao_official
IG_FETCH_LIMIT=10
TIKTOK_USERNAME=88baobao.official
TIKTOK_FETCH_LIMIT=10

# Posting mode: draft | queue | now
POST_MODE=queue

# Reframe captions older than this many days as throwbacks
THROWBACK_DAYS=14

# Cloudflare R2 — rehosts IG/TikTok media so Buffer can fetch it
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
