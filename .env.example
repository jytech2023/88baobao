# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---------- Auth.js (Auth0 provider) ----------
# openssl rand -base64 32
AUTH_SECRET=
# Auth0 application: Regular Web App
# Allowed Callback URL: {NEXT_PUBLIC_APP_URL}/api/auth/callback/auth0
AUTH_AUTH0_ID=
AUTH_AUTH0_SECRET=
AUTH_AUTH0_ISSUER=https://YOUR_TENANT.us.auth0.com

# ---------- Database (Neon) ----------
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# ---------- Cloudinary (image hosting & transforms) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ---------- Twilio (SMS) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------- Resend (Email) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---------- Google Places API (review fetching) ----------
GOOGLE_PLACES_API_KEY=

# ---------- Anthropic Claude (review classification) ----------
ANTHROPIC_API_KEY=

# ---------- Alerts (Feishu / Slack webhook) ----------
FEISHU_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ---------- Cron secret (for scheduled jobs) ----------
CRON_SECRET=
